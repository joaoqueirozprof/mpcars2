# ============================================
# MPCARS2 - Variaveis de Ambiente
# ============================================

POSTGRES_DB=mpcars2
POSTGRES_USER=mpcars2
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql://mpcars2:change-this-postgres-password@mpcars2-db:5432/mpcars2
REDIS_URL=redis://mpcars2-redis:6379/0
SECRET_KEY=change-this-secret-key

MPCARS2_API_PORT=8002
MPCARS2_WEB_PORT=3002
MPCARS2_PROXY_PORT=8091
MPCARS2_PGADMIN_PORT=8086

PGADMIN_DEFAULT_EMAIL=admin@mpcars.com
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password
